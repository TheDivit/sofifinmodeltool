{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C++ File",
      "type": "shell",
      "command": "clang++",
      "args": [
        "-std=c++17",
        "${file}",
        "-o",
        "${fileBasenameNoExtension}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Run FinStatement Parser",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "streamlit",
        "run",
        "${workspaceFolder}/app.py",
        "--server.headless",
        "true",
        "--server.port",
        "8501"
      ],
      "isBackground": true,
      "group": "test",
      "problemMatcher": []
    }
  ]
}
